{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Maven: spring-boot:run",
            "type": "shell",
            "command": "./mvnw spring-boot:run",
            "options": {
                "cwd": "${workspaceFolder}/server"
            },
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Maven: package server",
            "type": "shell",
            "command": "./mvnw -q package -DskipTests",
            "options": {
                "cwd": "${workspaceFolder}/server"
            },
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Maven: clean compile",
            "type": "shell",
            "command": "./mvnw clean compile",
            "options": {
                "cwd": "${workspaceFolder}/server"
            },
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "Maven: test",
            "type": "shell",
            "command": "./mvnw test",
            "options": {
                "cwd": "${workspaceFolder}/server"
            },
            "group": "test",
            "problemMatcher": []
        }
    ]
}
